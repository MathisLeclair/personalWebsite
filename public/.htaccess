<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect HTTP to HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  # Only skip rewrite for actual files (images, js, css, etc.)
  # Do NOT skip for directories — React Router must handle /stargate/, etc.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule . /index.html [L]
</IfModule>

# Disable directory listings site-wide
Options -Indexes